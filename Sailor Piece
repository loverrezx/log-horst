local WhitelistDiscordID = {
    "1305103475641942089",
    "1353408526696841230"
}

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local lp = Players.LocalPlayer

local function checkWhitelist()
    local success, discordID = pcall(function()
        return _G.Horst_DiscordID
    end)
    
    if not success or not discordID then
        return true
    end

    local isWhitelisted = false
    for _, id in ipairs(WhitelistDiscordID) do
        if tostring(discordID) == id then
            isWhitelisted = true
            break
        end
    end

    if not isWhitelisted then
        lp:Kick("คุณไม่มีสิทธิ์ใช้งานสคริปต์นี้ (Discord ID ไม่ได้รับอนุญาต)")
        return false
    end
    return true
end

if not checkWhitelist() then return end

_G.__HORST_DESC_RUN_ID = (_G.__HORST_DESC_RUN_ID or 0) + 1
local RUN_ID = _G.__HORST_DESC_RUN_ID

local function formatCompactNumber(n)
    local value = tonumber(n) or 0
    if value >= 1000000000 then
        return string.format("%.1fb", value / 1000000000):gsub("%.0b$", "b")
    end
    if value >= 1000000 then
        return string.format("%.1fm", value / 1000000):gsub("%.0m$", "m")
    end
    if value >= 1000 then
        return string.format("%.1fk", value / 1000):gsub("%.0k$", "k")
    end
    return tostring(math.floor(value))
end

local function readValueFlexible(node)
    if not node then return 0 end
    local okValue, v = pcall(function() return node.Value end)
    if okValue and v ~= nil then
        local n = tonumber(v)
        if n then return n end
    end
    local okText, t = pcall(function() return node.Text end)
    if okText and t ~= nil then
        local cleaned = tostring(t):gsub(",", ""):gsub("%s+", "")
        local n = tonumber(cleaned)
        if n then return n end
    end
    return 0
end

local function getBasicData()
    local data = lp:FindFirstChild("Data")
    local leaderstats = lp:FindFirstChild("leaderstats")
    local lv, money, gems, bounty = 0, 0, 0, 0
    if data then
        lv = readValueFlexible(data:FindFirstChild("Level"))
        money = readValueFlexible(data:FindFirstChild("Money"))
        gems = readValueFlexible(data:FindFirstChild("Gems"))
    end
    if leaderstats then
        bounty = readValueFlexible(leaderstats:FindFirstChild("Bounty"))
    end
    return lv, money, gems, bounty
end

local function getInventoryItems()
    local items = {}
    local inventoryPanel = lp:FindFirstChild("PlayerGui") and lp.PlayerGui:FindFirstChild("InventoryPanelUI")
    
    if inventoryPanel then
        if inventoryPanel:IsA("GuiObject") and inventoryPanel.Visible then
            inventoryPanel.Visible = false
        end
        local mainFrame = inventoryPanel:FindFirstChild("MainFrame")
        if mainFrame and mainFrame:IsA("GuiObject") and mainFrame.Visible then
            mainFrame.Visible = false
        end

        local storage = inventoryPanel:FindFirstChild("MainFrame")
            and inventoryPanel.MainFrame:FindFirstChild("Frame")
            and inventoryPanel.MainFrame.Frame:FindFirstChild("Content")
            and inventoryPanel.MainFrame.Frame.Content:FindFirstChild("Holder")
            and inventoryPanel.MainFrame.Frame.Content.Holder:FindFirstChild("StorageHolder")
            and inventoryPanel.MainFrame.Frame.Content.Holder.StorageHolder:FindFirstChild("Storage")
            
        if storage then
            for _, itemObj in ipairs(storage:GetChildren()) do
                if itemObj.Name:match("^Item_") then
                    local displayName = itemObj.Name:gsub("^Item_", "")
                    local quantity = 1
                    
                    local isVisible = false
                    pcall(function()
                        isVisible = itemObj.Visible
                    end)

                    if isVisible then
                        local quantityNode = itemObj:FindFirstChild("Slot")
                            and itemObj.Slot:FindFirstChild("Holder")
                            and itemObj.Slot.Holder:FindFirstChild("Quantity")
                        
                        if quantityNode then
                            quantity = readValueFlexible(quantityNode)
                            if quantity <= 0 then quantity = 1 end
                        end
                    else
                        quantity = 1
                    end
                    
                    table.insert(items, {name = displayName, qty = quantity})
                end
            end
        end
    end

    table.sort(items, function(a, b)
        return a.qty > b.qty
    end)

    local formattedItems = {}
    for _, item in ipairs(items) do
        table.insert(formattedItems, item.name .. " x" .. item.qty)
    end

    return formattedItems
end

local function getBackpackItems()
    local usedItems = {}
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            table.insert(usedItems, tool.Name)
        end
    end
    return usedItems
end

local function updateDescription()
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("RequestInventory"):FireServer()
    end)

    local lv, money, gems, bounty = getBasicData()
    local inventoryItems = getInventoryItems()
    local backpackItems = getBackpackItems()
    local parts = {}
    
    table.insert(parts, "Lv : " .. lv)
    table.insert(parts, "Money : " .. formatCompactNumber(money))
    table.insert(parts, "Gems : " .. formatCompactNumber(gems))
    table.insert(parts, "Bounty : " .. formatCompactNumber(bounty))
    
    if #backpackItems > 0 then
        table.insert(parts, "item use : " .. table.concat(backpackItems, ", "))
    end

    if #inventoryItems > 0 then
        table.insert(parts, "Item : " .. table.concat(inventoryItems, ", "))
    else
        table.insert(parts, "Item : None")
    end
    
    local message = table.concat(parts, " | ")
    message = message:gsub("|", "｜"):gsub(";", ",")
    
    local payload = {
        Level = lv,
        Money = money,
        Gems = gems,
        Bounty = bounty,
        Items = inventoryItems,
        ItemUse = backpackItems
    }
    local encodeJson = HttpService:JSONEncode(payload)
    
    if type(_G.Horst_SetDescription) == "function" then
        pcall(_G.Horst_SetDescription, message, encodeJson)
    end
end

task.spawn(function()
    while RUN_ID == _G.__HORST_DESC_RUN_ID do
        pcall(updateDescription)
        task.wait(2)
    end
end)

updateDescription()
